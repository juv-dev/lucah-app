---
import FoodToggle from './FoodToggle.astro';

interface IngredientRow {
  key: 'meat' | 'quinoa' | 'veggie';
  icon: string;
  title: string;
  hint: string;
  inputKey: 'meatCooked' | 'quinoaCooked' | 'veggieRaw';
  defaultValue: number;
  hasConversion: boolean;
  outputKey?: 'meatRaw' | 'quinoaRaw';
}

const rows: IngredientRow[] = [
  { key: 'meat',   icon: '🥩', title: 'Carne cocida',   hint: 'pierde ~39% de peso al cocinarse',       inputKey: 'meatCooked',   defaultValue: 60, hasConversion: true,  outputKey: 'meatRaw' },
  { key: 'quinoa', icon: '🌾', title: 'Quinua cocida',  hint: 'absorbe agua · 1g crudo ≈ 2.5g cocido',   inputKey: 'quinoaCooked', defaultValue: 40, hasConversion: true,  outputKey: 'quinoaRaw' },
  { key: 'veggie', icon: '🥕', title: 'Verdura cruda',  hint: 'va cruda, sin conversión',                inputKey: 'veggieRaw',    defaultValue: 30, hasConversion: false },
];
---
<section id="calculator" class="px-6 pb-12 scroll-mt-8">
  <div class="mx-auto max-w-3xl">
    <div class="rounded-3xl bg-surface border border-line p-6 sm:p-10 shadow-sm transition-shadow duration-300 hover:shadow-md animate-fade-up">
      <div class="flex items-start justify-between flex-wrap gap-5 mb-8">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">Ingredientes</h2>
          <p class="text-sm text-muted mt-1.5">Ingresá lo que come tu perro · calculamos el crudo al instante</p>
        </div>
        <FoodToggle />
      </div>

      <div class="space-y-3">
        {rows.map(row => (
          <div class="group rounded-2xl border border-line bg-cream/50 p-4 sm:p-5 transition-all duration-200 hover:border-mint-ink/40 hover:bg-cream">
            <div class="flex items-center gap-4">
              <div class="shrink-0 flex h-12 w-12 items-center justify-center rounded-2xl bg-surface text-2xl shadow-sm ring-1 ring-line/60">
                {row.icon}
              </div>
              <div class="flex-1 min-w-0">
                <div class="text-sm font-semibold text-ink">{row.title}</div>
                <div class="text-xs text-muted mt-0.5">{row.hint}</div>
              </div>
              <div class="relative shrink-0">
                <input
                  type="number"
                  min="0"
                  max="1000"
                  step="5"
                  value={row.defaultValue}
                  data-input={row.inputKey}
                  aria-label={row.title}
                  class="w-24 rounded-2xl border border-line bg-surface pl-3 pr-9 py-2.5 text-right font-bold text-ink tabular-nums focus:outline-none focus:border-mint-ink focus:ring-4 focus:ring-mint-ink/15 transition"
                />
                <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs font-medium text-muted pointer-events-none">g</span>
              </div>
            </div>

            {row.hasConversion && (
              <div class="mt-3 pt-3 border-t border-line/60 flex items-center justify-between text-xs">
                <span class="text-muted flex items-center gap-1.5">
                  <svg class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                    <path fill-rule="evenodd" d="M10 3a1 1 0 0 1 1 1v10.586l3.293-3.293a1 1 0 1 1 1.414 1.414l-5 5a1 1 0 0 1-1.414 0l-5-5a1 1 0 1 1 1.414-1.414L9 14.586V4a1 1 0 0 1 1-1Z" clip-rule="evenodd"/>
                  </svg>
                  Crudo a pesar antes de cocinar
                </span>
                <span class="font-bold text-mint-ink tabular-nums transition-all duration-300" data-output={row.outputKey}>— g</span>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
