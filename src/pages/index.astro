---
import MainLayout from '../layouts/MainLayout.astro';
import Hero from '../components/Hero.astro';
import CalculatorCard from '../components/CalculatorCard.astro';
import ResultCard from '../components/ResultCard.astro';
---
<MainLayout>
  <main>
    <Hero />
    <CalculatorCard />
    <ResultCard />
    <footer class="px-6 pb-10 text-center text-xs text-muted">
      Hecho con 🐾 · Conversiones basadas en ratios reales de cocción
    </footer>
  </main>

  <script>
    import { calculatePortion, pickTotal, type FoodMode, type IngredientInput } from '../lib/calculator';

    type InputKey = keyof IngredientInput;

    const state: IngredientInput & { mode: FoodMode } = {
      meatCooked: 60,
      quinoaCooked: 40,
      veggieRaw: 30,
      mode: 'raw',
    };

    const MODE_LABELS: Record<FoodMode, string> = { raw: 'crudo', cooked: 'cocido' };
    const CAPTIONS: Record<FoodMode, string> = {
      raw: 'lo que vas a pesar antes de cocinar',
      cooked: 'lo que va en el plato servido',
    };

    const $ = <T extends Element>(sel: string, root: ParentNode = document) =>
      root.querySelector<T>(sel);
    const $$ = <T extends Element>(sel: string, root: ParentNode = document) =>
      Array.from(root.querySelectorAll<T>(sel));

    const totalEl        = $<HTMLElement>('#result-total');
    const modeLabelEl    = $<HTMLElement>('[data-result-mode-label]');
    const captionEl      = $<HTMLElement>('[data-result-caption]');
    const breakdownEl    = $<HTMLElement>('[data-breakdown]');
    const foodToggle     = $<HTMLElement>('[data-food-toggle]');
    const meatRawOutput   = $<HTMLElement>('[data-output="meatRaw"]');
    const quinoaRawOutput = $<HTMLElement>('[data-output="quinoaRaw"]');

    function pop(el: HTMLElement | null) {
      if (!el) return;
      el.classList.remove('animate-pop');
      void el.offsetWidth;
      el.classList.add('animate-pop');
    }

    function renderBreakdown(ingredients: ReturnType<typeof calculatePortion>['breakdown']) {
      if (!breakdownEl) return;
      breakdownEl.innerHTML = ingredients.map(b => {
        const amount = state.mode === 'raw' ? b.raw : b.cooked;
        const tag = b.servedRaw
          ? '<span class="inline-flex items-center rounded-full bg-mint/70 text-mint-ink text-[10px] font-semibold px-2 py-0.5">siempre cruda</span>'
          : (state.mode === 'raw'
              ? '<span class="inline-flex items-center rounded-full bg-surface/70 text-muted text-[10px] font-semibold px-2 py-0.5">a pesar</span>'
              : '<span class="inline-flex items-center rounded-full bg-surface/70 text-muted text-[10px] font-semibold px-2 py-0.5">servido</span>');
        return `
          <div class="rounded-2xl bg-surface/70 backdrop-blur border border-line/60 p-4 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-sm">
            <div class="flex items-center justify-between gap-2">
              <div class="flex items-center gap-2">
                <span class="text-xl leading-none">${b.icon}</span>
                <span class="text-xs font-semibold uppercase tracking-wider text-muted">${b.label}</span>
              </div>
              ${tag}
            </div>
            <div class="mt-2 text-2xl font-bold text-ink tabular-nums">${amount}<span class="text-sm font-medium text-muted ml-1">g</span></div>
          </div>`;
      }).join('');
    }

    function render() {
      const result = calculatePortion({
        meatCooked:   state.meatCooked,
        quinoaCooked: state.quinoaCooked,
        veggieRaw:    state.veggieRaw,
      });

      const meat   = result.breakdown.find(b => b.key === 'meat')!;
      const quinoa = result.breakdown.find(b => b.key === 'quinoa')!;
      if (meatRawOutput)   meatRawOutput.textContent   = `${meat.raw} g`;
      if (quinoaRawOutput) quinoaRawOutput.textContent = `${quinoa.raw} g`;

      if (totalEl) {
        totalEl.textContent = pickTotal(result, state.mode).toString();
        pop(totalEl);
      }
      if (modeLabelEl) modeLabelEl.textContent = MODE_LABELS[state.mode];
      if (captionEl)   captionEl.textContent   = CAPTIONS[state.mode];

      renderBreakdown(result.breakdown);
    }

    $$<HTMLInputElement>('[data-input]').forEach(input => {
      input.addEventListener('input', e => {
        const target = e.target as HTMLInputElement;
        const v = parseFloat(target.value);
        if (!Number.isFinite(v) || v < 0) return;
        const key = target.dataset.input as InputKey;
        state[key] = v;
        render();
      });
    });

    foodToggle?.addEventListener('click', e => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-mode]');
      if (!btn) return;
      state.mode = btn.dataset.mode as FoodMode;
      $$<HTMLElement>('[data-mode]', foodToggle).forEach(b => {
        b.setAttribute('aria-selected', String(b.dataset.mode === state.mode));
      });
      render();
    });

    render();
  </script>
</MainLayout>
