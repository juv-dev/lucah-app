---
// Plan Alimenticio Lucah - Astro page
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="theme-color" content="#1B2A6B" />
  <meta name="description" content="Plan alimenticio blanda terapéutica para Lucah - Familia Ugaz Vegas" />
  <title>Plan Alimenticio · Lucah 🐶</title>
  <style>
:root {
    --navy:   #1B2A6B;
    --purple: #5C3D9E;
    --lavend: #EAE6F8;
    --green:  #2E7D32;
    --red:    #C62828;
    --orange: #E65100;
    --gold:   #F59E0B;
    --teal:   #006064;
    --white:  #FFFFFF;
    --gray:   #F5F5F5;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
         background: #F0EDF8; min-height: 100vh; padding-bottom: 80px; }

  /* HEADER */
  .app-header {
    background: linear-gradient(135deg, var(--navy) 0%, var(--purple) 100%);
    color: #fff; padding: 20px 16px 14px; text-align: center;
    position: sticky; top: 0; z-index: 100;
    box-shadow: 0 2px 12px rgba(0,0,0,0.3);
  }
  .app-header h1 { font-size: 1.3rem; font-weight: 700; letter-spacing: .5px; }
  .app-header p  { font-size: .78rem; opacity: .85; margin-top: 2px; }

  /* TABS */
  .tabs {
    display: flex; background: var(--navy);
    position: sticky; top: 72px; z-index: 99;
    border-bottom: 2px solid var(--purple);
    overflow-x: auto; scrollbar-width: none;
  }
  .tabs::-webkit-scrollbar { display: none; }
  .tab {
    flex: 1; min-width: 70px; padding: 10px 6px; font-size: .72rem;
    font-weight: 600; color: rgba(255,255,255,.6); text-align: center;
    cursor: pointer; border: none; background: none;
    border-bottom: 3px solid transparent; transition: all .2s;
    white-space: nowrap;
  }
  .tab.active { color: #fff; border-bottom-color: var(--gold); }
  .tab-icon { font-size: 1.1rem; display: block; margin-bottom: 2px; }

  /* CONTENT */
  .content { display: none; padding: 14px; animation: fadeIn .25s ease; }
  .content.active { display: block; }
  @keyframes fadeIn { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:none; } }

  /* CARDS */
  .card {
    background: #fff; border-radius: 14px; padding: 16px;
    margin-bottom: 14px; box-shadow: 0 2px 8px rgba(0,0,0,.08);
  }
  .card-title {
    font-size: .8rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: .8px; color: var(--purple); margin-bottom: 12px;
    display: flex; align-items: center; gap: 6px;
  }
  .card-title .badge {
    font-size: .7rem; background: var(--lavend); color: var(--purple);
    padding: 2px 8px; border-radius: 20px; font-weight: 600;
  }

  /* RATION HEADER */
  .ration-header {
    border-radius: 10px; padding: 10px 14px; margin-bottom: 10px;
    color: #fff; font-weight: 700; font-size: .9rem;
    display: flex; justify-content: space-between; align-items: center;
  }
  .ration-morning { background: linear-gradient(135deg,#1565C0,#42A5F5); }
  .ration-noon    { background: linear-gradient(135deg,#6A1B9A,#AB47BC); }
  .ration-night   { background: linear-gradient(135deg,#1B5E20,#43A047); }

  /* INGREDIENT ROW */
  .ing-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 10px 0; border-bottom: 1px solid #F0EDF8;
  }
  .ing-row:last-child { border-bottom: none; }
  .ing-left { display: flex; align-items: center; gap: 10px; }
  .ing-icon { font-size: 1.3rem; width: 36px; text-align: center; }
  .ing-name { font-size: .9rem; font-weight: 600; color: #222; }
  .ing-sub  { font-size: .72rem; color: #888; margin-top: 1px; }
  .ing-amounts { text-align: right; }
  .ing-cocido { font-size: 1rem; font-weight: 700; color: var(--navy); }
  .ing-crudo  { font-size: .72rem; color: #888; margin-top: 1px; }
  .crudo-val  { color: var(--teal); font-weight: 700; }

  /* TOTAL ROW */
  .total-row {
    background: linear-gradient(135deg, var(--navy), var(--purple));
    border-radius: 10px; padding: 12px 16px; margin-top: 10px;
    display: flex; justify-content: space-between; align-items: center; color: #fff;
  }
  .total-label { font-size: .8rem; opacity: .9; }
  .total-val   { font-size: 1.3rem; font-weight: 800; }

  /* PILL STATS */
  .stats-row { display: flex; gap: 8px; margin-bottom: 14px; flex-wrap: wrap; }
  .stat-pill {
    flex: 1; min-width: 90px; background: #fff; border-radius: 12px;
    padding: 12px 10px; text-align: center; box-shadow: 0 2px 6px rgba(0,0,0,.08);
  }
  .stat-num  { font-size: 1.4rem; font-weight: 800; color: var(--navy); }
  .stat-unit { font-size: .65rem; color: #888; }
  .stat-lbl  { font-size: .72rem; color: #555; margin-top: 2px; }

  /* PERCENT BAR */
  .pct-bar-wrap { margin-bottom: 14px; }
  .pct-bar-label { display: flex; justify-content: space-between;
                   font-size: .78rem; font-weight: 600; margin-bottom: 4px; color: #444; }
  .pct-bar-track { background: #E8E0F0; border-radius: 10px; height: 12px; overflow: hidden; }
  .pct-bar-fill  { height: 100%; border-radius: 10px; transition: width .6s ease; }

  /* SHOPPING LIST */
  .shop-item {
    display: flex; align-items: center; gap: 12px;
    padding: 14px; border-radius: 12px; margin-bottom: 8px;
    background: #fff; box-shadow: 0 1px 4px rgba(0,0,0,.07);
    cursor: pointer; transition: opacity .2s;
  }
  .shop-item.checked { opacity: .5; }
  .shop-item.checked .shop-name { text-decoration: line-through; }
  .shop-cb {
    width: 24px; height: 24px; border-radius: 50%;
    border: 2px solid var(--purple); background: #fff;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0; transition: all .2s; font-size: .9rem;
  }
  .shop-item.checked .shop-cb { background: var(--green); border-color: var(--green); color: #fff; }
  .shop-info { flex: 1; }
  .shop-name { font-size: .92rem; font-weight: 700; color: #222; }
  .shop-detail { font-size: .75rem; color: #888; margin-top: 2px; }
  .shop-price {
    text-align: right; flex-shrink: 0;
    font-size: .9rem; font-weight: 800; color: var(--purple);
  }
  .shop-price-sub { font-size: .68rem; color: #aaa; }

  /* COST BOX */
  .cost-box {
    background: linear-gradient(135deg, var(--navy), var(--purple));
    color: #fff; border-radius: 14px; padding: 18px;
    margin-bottom: 14px; text-align: center;
  }
  .cost-box .main-cost { font-size: 2.2rem; font-weight: 900; letter-spacing: -1px; }
  .cost-box .cost-lbl  { font-size: .78rem; opacity: .85; margin-top: 2px; }
  .cost-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 14px; }
  .cost-cell {
    background: rgba(255,255,255,.15); border-radius: 10px; padding: 10px;
    text-align: center;
  }
  .cost-cell .val { font-size: 1.1rem; font-weight: 700; }
  .cost-cell .lbl { font-size: .65rem; opacity: .8; margin-top: 2px; }

  /* SCHEDULE CARD */
  .sched-row {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 0; border-bottom: 1px solid #F0EDF8;
  }
  .sched-row:last-child { border-bottom: none; }
  .sched-num {
    width: 32px; height: 32px; border-radius: 50%;
    background: var(--lavend); color: var(--purple);
    font-weight: 800; font-size: .85rem;
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
  }
  .sched-info { flex: 1; }
  .sched-title { font-size: .88rem; font-weight: 700; color: #222; }
  .sched-sub   { font-size: .72rem; color: #888; margin-top: 2px; }

  /* INSTRUCTIONS */
  .step-list { list-style: none; }
  .step-list li {
    display: flex; gap: 10px; padding: 8px 0;
    border-bottom: 1px solid #F0EDF8; font-size: .88rem; color: #333;
  }
  .step-list li:last-child { border-bottom: none; }
  .step-num {
    width: 22px; height: 22px; border-radius: 50%; flex-shrink: 0;
    font-size: .7rem; font-weight: 800; color: #fff;
    display: flex; align-items: center; justify-content: center; margin-top: 1px;
  }
  .s-blue   { background: #1565C0; }
  .s-purple { background: var(--purple); }
  .s-green  { background: var(--green); }

  /* ALERT BANNER */
  .alert {
    border-radius: 10px; padding: 12px 14px; margin-bottom: 12px;
    font-size: .82rem; font-weight: 600; display: flex; gap: 8px;
  }
  .alert-warn  { background: #FFF3E0; color: var(--orange); }
  .alert-green { background: #E8F5E9; color: var(--green); }
  .alert-red   { background: #FFEBEE; color: var(--red); }
  .alert-info  { background: var(--lavend); color: var(--purple); }

  /* TRACKER */
  .tracker-week {
    background: #fff; border-radius: 12px; padding: 14px;
    margin-bottom: 10px; box-shadow: 0 1px 4px rgba(0,0,0,.07);
  }
  .tracker-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
  .tracker-label { font-weight: 700; font-size: .9rem; color: var(--navy); }
  .tracker-date  { font-size: .72rem; color: #888; }
  .heces-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 6px; }
  .heces-cell { text-align: center; }
  .heces-lbl  { font-size: .65rem; color: #888; margin-bottom: 4px; }
  .heces-btns { display: flex; gap: 3px; justify-content: center; flex-wrap: wrap; }
  .heces-btn  {
    padding: 4px 6px; border-radius: 6px; border: 1.5px solid #DDD;
    font-size: .7rem; font-weight: 700; background: #fff;
    cursor: pointer; color: #666; transition: all .15s;
  }
  .heces-btn.sel-F { background: var(--green);  border-color: var(--green);  color: #fff; }
  .heces-btn.sel-M { background: #F59E0B; border-color: #F59E0B; color: #fff; }
  .heces-btn.sel-B { background: var(--orange); border-color: var(--orange); color: #fff; }
  .heces-btn.sel-A { background: var(--red);   border-color: var(--red);   color: #fff; }
  .obs-input {
    width: 100%; margin-top: 8px; padding: 8px 10px; border-radius: 8px;
    border: 1.5px solid #E0E0E0; font-size: .8rem; font-family: inherit;
    resize: none; outline: none; color: #333;
  }
  .obs-input:focus { border-color: var(--purple); }

  /* FOOTER NOTE */
  .footer-note {
    text-align: center; font-size: .7rem; color: #AAA;
    padding: 10px; margin-top: 4px;
  }

  /* ADD-TO-HOME BANNER */
  .ath-banner {
    background: linear-gradient(135deg, var(--gold), #F97316);
    color: #fff; padding: 12px 16px; font-size: .8rem;
    font-weight: 600; text-align: center; display: flex;
    align-items: center; justify-content: center; gap: 8px;
  }
  .ath-banner button {
    background: rgba(255,255,255,.25); border: none; color: #fff;
    padding: 4px 10px; border-radius: 20px; font-size: .75rem;
    font-weight: 700; cursor: pointer; margin-left: 4px;
  }
  </style>
</head>
<body>
<!-- ADD TO HOME SCREEN HINT -->
<div class="ath-banner" id="athBanner">
  📱 Agrégala a tu pantalla de inicio para usarla como app
  <button onclick="document.getElementById('athBanner').style.display='none'">✕</button>
</div>

<!-- HEADER -->
<div class="app-header">
  <h1>🐶 Plan Alimenticio · Lucah</h1>
  <p>Dieta Blanda Terapéutica · Familia Ugaz Vegas · Abril 2026</p>
</div>

<!-- TABS -->
<div class="tabs">
  <button class="tab active" onclick="showTab('raciones')">
    <span class="tab-icon">🍽️</span>Raciones
  </button>
  <button class="tab" onclick="showTab('compras')">
    <span class="tab-icon">🛒</span>Compras
  </button>
  <button class="tab" onclick="showTab('instrucciones')">
    <span class="tab-icon">🍳</span>Cómo cocinar
  </button>
  <button class="tab" onclick="showTab('seguimiento')">
    <span class="tab-icon">📊</span>Seguimiento
  </button>
  <button class="tab" onclick="showTab('transicion')">
    <span class="tab-icon">🔄</span>Transición
  </button>
</div>

<!-- ════════════════════════════════════════════════════
     TAB 1 — RACIONES
════════════════════════════════════════════════════ -->
<div class="content active" id="tab-raciones">

  <!-- Resumen del día -->
  <div class="stats-row">
    <div class="stat-pill">
      <div class="stat-num">300</div>
      <div class="stat-unit">g cocido</div>
      <div class="stat-lbl">Total/día</div>
    </div>
    <div class="stat-pill">
      <div class="stat-num">3</div>
      <div class="stat-unit">raciones</div>
      <div class="stat-lbl">Comidas</div>
    </div>
    <div class="stat-pill">
      <div class="stat-num">100</div>
      <div class="stat-unit">g/ración</div>
      <div class="stat-lbl">Cocido</div>
    </div>
  </div>

  <!-- Barras de porcentaje -->
  <div class="card">
    <div class="card-title">📊 Composición de la dieta</div>
    <div class="pct-bar-wrap">
      <div class="pct-bar-label"><span>🥩 Carne</span><span>70% · 210 g/día</span></div>
      <div class="pct-bar-track"><div class="pct-bar-fill" style="width:70%;background:linear-gradient(90deg,#1565C0,#42A5F5)"></div></div>
    </div>
    <div class="pct-bar-wrap">
      <div class="pct-bar-label"><span>🌾 Quinua</span><span>20% · 60 g/día</span></div>
      <div class="pct-bar-track"><div class="pct-bar-fill" style="width:20%;background:linear-gradient(90deg,#6A1B9A,#AB47BC)"></div></div>
    </div>
    <div class="pct-bar-wrap" style="margin-bottom:0">
      <div class="pct-bar-label"><span>🥕 Verduras crudas</span><span>10% · 30 g/día</span></div>
      <div class="pct-bar-track"><div class="pct-bar-fill" style="width:10%;background:linear-gradient(90deg,#1B5E20,#43A047)"></div></div>
    </div>
  </div>

  <!-- RACIÓN 1 -->
  <div class="card">
    <div class="ration-header ration-morning">
      <span>🌅 1ª Ración — Mañana</span>
      <span>100 g cocido</span>
    </div>
    <div class="ing-row">
      <div class="ing-left">
        <div class="ing-icon">🥩</div>
        <div>
          <div class="ing-name">Carne sancochada</div>
          <div class="ing-sub">pesar crudo antes de cocinar</div>
        </div>
      </div>
      <div class="ing-amounts">
        <div class="ing-cocido">70 g</div>
        <div class="ing-crudo">crudo: <span class="crudo-val">97 g</span></div>
      </div>
    </div>
    <div class="ing-row">
      <div class="ing-left">
        <div class="ing-icon">🌾</div>
        <div>
          <div class="ing-name">Quinua cocida</div>
          <div class="ing-sub">lavar bien antes de cocinar</div>
        </div>
      </div>
      <div class="ing-amounts">
        <div class="ing-cocido">20 g</div>
        <div class="ing-crudo">crudo: <span class="crudo-val">8 g</span></div>
      </div>
    </div>
    <div class="ing-row">
      <div class="ing-left">
        <div class="ing-icon">🥕</div>
        <div>
          <div class="ing-name">Verduras frescas crudas</div>
          <div class="ing-sub">zanahoria rallada, zapallo, brócoli, etc.</div>
        </div>
      </div>
      <div class="ing-amounts">
        <div class="ing-cocido">10 g</div>
        <div class="ing-crudo"><span class="crudo-val">se dan crudas</span></div>
      </div>
    </div>
    <div class="total-row">
      <div>
        <div class="total-label">Total cocido</div>
        <div style="font-size:.72rem;opacity:.75">115 g total → 100 g servido</div>
      </div>
      <div class="total-val">100 g</div>
    </div>
  </div>

  <!-- RACIÓN 2 -->
  <div class="card">
    <div class="ration-header ration-noon">
      <span>☀️ 2ª Ración — Mediodía</span>
      <span>100 g cocido</span>
    </div>
    <div class="ing-row">
      <div class="ing-left"><div class="ing-icon">🥩</div><div><div class="ing-name">Carne sancochada</div><div class="ing-sub">pesar crudo antes de cocinar</div></div></div>
      <div class="ing-amounts"><div class="ing-cocido">70 g</div><div class="ing-crudo">crudo: <span class="crudo-val">97 g</span></div></div>
    </div>
    <div class="ing-row">
      <div class="ing-left"><div class="ing-icon">🌾</div><div><div class="ing-name">Quinua cocida</div><div class="ing-sub">lavar bien antes de cocinar</div></div></div>
      <div class="ing-amounts"><div class="ing-cocido">20 g</div><div class="ing-crudo">crudo: <span class="crudo-val">8 g</span></div></div>
    </div>
    <div class="ing-row">
      <div class="ing-left"><div class="ing-icon">🥕</div><div><div class="ing-name">Verduras frescas crudas</div><div class="ing-sub">zanahoria rallada, zapallo, brócoli, etc.</div></div></div>
      <div class="ing-amounts"><div class="ing-cocido">10 g</div><div class="ing-crudo">crudo: <span class="crudo-val">13 g</span></div></div>
    </div>
    <div class="total-row">
      <div><div class="total-label">Total cocido</div><div style="font-size:.72rem;opacity:.75">115 g total → 100 g servido</div></div>
      <div class="total-val">100 g</div>
    </div>
  </div>

  <!-- RACIÓN 3 -->
  <div class="card">
    <div class="ration-header ration-night">
      <span>🌆 3ª Ración — Tarde</span>
      <span>100 g cocido</span>
    </div>
    <div class="ing-row">
      <div class="ing-left"><div class="ing-icon">🥩</div><div><div class="ing-name">Carne sancochada</div><div class="ing-sub">pesar crudo antes de cocinar</div></div></div>
      <div class="ing-amounts"><div class="ing-cocido">70 g</div><div class="ing-crudo">crudo: <span class="crudo-val">97 g</span></div></div>
    </div>
    <div class="ing-row">
      <div class="ing-left"><div class="ing-icon">🌾</div><div><div class="ing-name">Quinua cocida</div><div class="ing-sub">lavar bien antes de cocinar</div></div></div>
      <div class="ing-amounts"><div class="ing-cocido">20 g</div><div class="ing-crudo">crudo: <span class="crudo-val">8 g</span></div></div>
    </div>
    <div class="ing-row">
      <div class="ing-left"><div class="ing-icon">🥕</div><div><div class="ing-name">Verduras frescas crudas</div><div class="ing-sub">zanahoria rallada, zapallo, brócoli, etc.</div></div></div>
      <div class="ing-amounts"><div class="ing-cocido">10 g</div><div class="ing-crudo">crudo: <span class="crudo-val">13 g</span></div></div>
    </div>
    <div class="total-row">
      <div><div class="total-label">Total cocido</div><div style="font-size:.72rem;opacity:.75">115 g total → 100 g servido</div></div>
      <div class="total-val">100 g</div>
    </div>
  </div>

  <!-- Notas -->
  <div class="alert alert-green">✅ La quinua firma las heces — aporta fibra que da consistencia al colon de Lucah.</div>
  <div class="alert alert-warn">⚠️ Servir siempre a temperatura ambiente. Sin sal, sin condimentos.</div>
  <div class="alert alert-info">💡 Cocina para 3-4 días de una vez. Refrigera porciones de 100 g y solo calienta al servir.</div>

  <div class="footer-note">Total diario: ~345 g preparado → 300 g servido (verduras van crudas)</div>
</div>

<!-- ════════════════════════════════════════════════════
     TAB 2 — COMPRAS
════════════════════════════════════════════════════ -->
<div class="content" id="tab-compras">

  <div class="cost-box">
    <div style="font-size:.8rem;opacity:.8;margin-bottom:4px">💰 Total cada 2 semanas</div>
    <div class="main-cost">S/ 79.05</div>
    <div class="cost-lbl">Compra quincenal · Makro Perú</div>
    <div class="cost-grid">
      <div class="cost-cell"><div class="val">S/ 5.69</div><div class="lbl">por día</div></div>
      <div class="cost-cell"><div class="val">S/ 1.90</div><div class="lbl">por ración</div></div>
      <div class="cost-cell"><div class="val">S/ 159</div><div class="lbl">mensual est.</div></div>
      <div class="cost-cell"><div class="val">14 días</div><div class="lbl">de duración</div></div>
    </div>
  </div>

  <div class="card">
    <div class="card-title">🛒 Lista de compras <span class="badge" id="checked-count">0 / 3</span></div>

    <div class="shop-item" id="item-carne" onclick="toggleItem('carne')">
      <div class="shop-cb" id="cb-carne"></div>
      <div class="shop-info">
        <div class="shop-name">🥩 Carne magra (aguja / pecho de res)</div>
        <div class="shop-detail">4.2 kg · Corte económico · Makro</div>
      </div>
      <div class="shop-price">
        S/ 71.40
        <div class="shop-price-sub">S/17.00/kg</div>
      </div>
    </div>

    <div class="shop-item" id="item-quinua" onclick="toggleItem('quinua')">
      <div class="shop-cb" id="cb-quinua"></div>
      <div class="shop-info">
        <div class="shop-name">🌾 Quinua blanca ARO (bolsa 1 kg)</div>
        <div class="shop-detail">0.5 kg necesario · 1 bolsa dura ~6 semanas</div>
